        }, {
          "componentAttributes" : {
            "richTextValue" : "<div\n  style=\"\n    width:320px;\n    background:#ffffff;\n    border:1px solid #e5e7eb;\n    border-radius:16px;\n    box-shadow:0 4px 14px rgba(2,6,23,0.06);\n    padding:16px;\n    color:#0f172a;\n    font-family: Arial, Helvetica, sans-serif;\n    margin: 20px auto; /* centers the card */\n  \"\n>\n  <!-- Tier badge -->\n  <div style=\"display:flex; align-items:center; gap:8px; margin-bottom:10px;\">\n    <span\n      title=\"Tier badge\"\n      style=\"\n        width:26px; height:26px; border-radius:8px; flex-shrink:0;\n        display:flex; align-items:center; justify-content:center;\n        background:#f8fafc; border:1px solid #e5e7eb; font-size:14px;\n      \"\n      >🏅</span>\n    <span style=\"font-weight:800; letter-spacing:0.02em;\">SILVER LEVEL</span>\n  </div>\n\n  <!-- Partner name -->\n  <div style=\"font-weight:800; font-size:22px; line-height:1.2; margin-bottom:12px;\">\n    CTW Partners\n  </div>\n\n  <!-- Benefits list -->\n  <ul style=\"list-style:none; padding:0; margin:0;\">\n    <li style=\"display:flex; gap:10px; align-items:flex-start; margin-bottom:10px;\">\n      <span style=\"line-height:1.5;\">\n        Access to extra marketing and development funds\n      </span>\n    </li>\n    <li style=\"display:flex; gap:10px; align-items:flex-start; margin-bottom:10px;\">\n      <span style=\"line-height:1.5;\">\n        Joint account planning with executive sponsorship\n      </span>\n    </li>\n    <li style=\"display:flex; gap:10px; align-items:flex-start;\">\n      <span style=\"line-height:1.5;\">\n        Priority sales referral\n      </span>\n    </li>\n  </ul>\n\n  <!-- Optional soft info panel (toggle by removing if not needed) -->\n  <div\n    style=\"\n      margin-top:14px;\n      padding:12px;\n      border:1px solid #e5e7eb;\n      background:#F2FAFF;\n      border-radius:12px;\n      font-size:14px;\n      color:#475569;\n    \"\n  >\n    Tip: Benefits increase with higher tiers. Ask Agentforce how to reach the next level.\n  </div>\n</div>"
          },
          "componentName" : "forceCommunity:htmlBlock",
          "id" : "c7e41c51-dd64-426a-9177-7fdcd539a5d1",
          "renderPriority" : "NEUTRAL",
          "renditionMap" : { },
          "type" : "component"
        }, {
          "componentAttributes" : {
            "richTextValue" : "<div\n  style=\"\n    width:320px;\n    background:#ffffff;\n    border:1px solid #e5e7eb;\n    border-radius:16px;\n    box-shadow:0 4px 14px rgba(2,6,23,0.06);\n    padding:16px;\n    color:#0f172a;\n    font-family: Arial, Helvetica, sans-serif;\n    margin: 20px auto; /* this centers it */\n  \"\n>\n  <!-- Header -->\n  <div style=\"font-weight:800; font-size:18px; margin-bottom:12px;\">\n    Partner Scorecard\n  </div>\n\n  <!-- Pipeline row -->\n  <div style=\"display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;\">\n    <span style=\"font-weight:600;\">Pipeline</span>\n    <span style=\"font-weight:700;\">$230 k</span>\n  </div>\n\n  <!-- Renewals -->\n  <div style=\"display:flex; justify-content:space-between; align-items:center; margin:10px 0 6px;\">\n    <span style=\"font-weight:600;\">Renewals</span>\n    <span style=\"font-weight:700;\">75/100</span>\n  </div>\n  <div style=\"height:10px; background:#e5edf7; border-radius:999px; overflow:hidden; border:1px solid #dbe3ef;\">\n    <div style=\"height:100%; width:75%; background:#2a81ff; border-radius:999px;\"></div>\n  </div>\n\n  <!-- Training -->\n  <div style=\"display:flex; justify-content:space-between; align-items:center; margin:14px 0 6px;\">\n    <span style=\"font-weight:600;\">Training</span>\n    <span style=\"font-weight:700;\">50 %</span>\n  </div>\n  <div style=\"height:10px; background:#e5edf7; border-radius:999px; overflow:hidden; border:1px solid #dbe3ef;\">\n    <div style=\"height:100%; width:50%; background:#14b8a6; border-radius:999px;\"></div>\n  </div>\n\n  <!-- Ask Agentforce bubble -->\n  <div\n    style=\"\n      margin-top:14px;\n      padding:12px;\n      border:1px solid #bae6fd;\n      background:#f0f9ff;\n      border-radius:12px;\n      display:flex;\n      gap:10px;\n      align-items:flex-start;\n    \"\n  >\n    <div\n      style=\"\n        width:28px; height:28px; border-radius:999px;\n        background:#e0f2fe; display:flex; align-items:center; justify-content:center;\n        font-weight:700; color:#0b6efd; flex-shrink:0;\n      \"\n      title=\"Agentforce\"\n    >◎</div>\n    <div>\n      <div style=\"font-weight:700; margin-bottom:2px;\">Ask Agentforce</div>\n      <div style=\"color:#475569; line-height:1.4;\">Show me my upcoming renewals.</div>\n    </div>\n  </div>\n</div>"
