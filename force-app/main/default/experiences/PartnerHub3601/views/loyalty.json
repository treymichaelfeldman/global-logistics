          "componentAttributes" : {
            "richTextValue" : "<div style=\"max-width:1100px;margin:24px auto;font-family:Arial,Helvetica,sans-serif;color:#0f172a;\">\n  <!-- Header -->\n  <div style=\"text-align:center;margin-bottom:16px;background:#ECF3FE;border-radius:14px;padding:14px;\">\n    <h2 style=\"margin:0;font-size:28px;\">Partner Loyalty Program</h2>\n    <p style=\"margin:6px 0 0;color:#6b7280;font-size:14px;\">Track your tier, points, promos, and rewards.</p>\n  </div>\n\n  <!-- Tier / Points Banner (single continuous gradient) -->\n  <div style=\"\n    position:relative;\n    background:linear-gradient(90deg,#0b63e5 0%, #0e1a2f 100%);\n    border-radius:14px; overflow:hidden; color:#fff;\n    margin-bottom:16px; border:1px solid #dbeafe;\n  \">\n    <div style=\"display:grid;grid-template-columns:1fr 2fr;gap:0;\">\n      <!-- Points Column -->\n      <div style=\"padding:18px 20px;\">\n        <div style=\"opacity:.9;font-size:13px;margin-bottom:6px;\">Reward Points</div>\n        <div style=\"font-size:36px;font-weight:800;line-height:1;\">970</div>\n        <div style=\"opacity:.85;font-size:12px;margin-top:4px;\">Point Balance</div>\n      </div>\n\n      <!-- Tier Meter Column (transparent background so no blue patch) -->\n      <div style=\"padding:16px 20px;background:transparent;\">\n        <div style=\"display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;\">\n          <div>\n            <span style=\"background:#cbd5e1;color:#0f172a;font-weight:700;font-size:11px;border-radius:999px;padding:6px 10px;\">SILVER</span>\n            <span style=\"margin-left:10px;opacity:.9;font-size:12px;\">Your Tier</span>\n          </div>\n          <div style=\"font-size:12px;opacity:.95;\">Tier Points : <b>970</b></div>\n        </div>\n\n        <!-- Labels -->\n        <div style=\"display:flex;justify-content:space-between;font-size:12px;opacity:.95;margin:2px 0 8px;\">\n          <span>SILVER</span><span>GOLD</span><span>PLATINUM</span>\n        </div>\n\n        <!-- Track -->\n        <div style=\"position:relative;height:8px;background:rgba(255,255,255,.28);border-radius:999px;\">\n          <!-- Fill to current progress (970/5000 ≈ 19.4%) -->\n          <div style=\"position:absolute;left:0;top:0;height:8px;border-radius:999px;\n            width:19.4%; background:#60a5fa;\"></div>\n\n          <!-- Milestones (0, 2500, 5000) -->\n          <div style=\"position:absolute;left:0;top:-6px;width:2px;height:20px;background:#fff;opacity:.9;\"></div>\n          <div style=\"position:absolute;left:50%;top:-6px;width:2px;height:20px;background:#fff;opacity:.85;\"></div>\n          <div style=\"position:absolute;right:0;top:-6px;width:2px;height:20px;background:#fff;opacity:.9;\"></div>\n        </div>\n\n        <!-- Scale text -->\n        <div style=\"display:flex;justify-content:space-between;font-size:11px;opacity:.95;margin-top:6px;\">\n          <span>0 pts</span><span>2500 pts</span><span>5000 pts</span>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <!-- Promotions (3 cards) -->\n  <div style=\"display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:14px;\">\n    <div style=\"background:#ECF3FE;border-radius:14px;color:#0f172a;padding:16px;min-height:140px;border:1px solid #0ea5e9;\">\n      <div style=\"font-size:12px;opacity:.9;margin-bottom:6px;\">10% Bonus</div>\n      <div style=\"font-weight:800;font-size:18px;line-height:1.2;\">Earn 10% Bonus on AI Sales through December!</div>\n      <button style=\"margin-top:10px;background:#0062E0;border:none;color:#fff;padding:8px 12px;border-radius:10px;font-weight:700;cursor:pointer;\">\n        Join Challenge\n      </button>\n    </div>\n    <div style=\"background:#ECF3FE;border-radius:14px;color:#0f172a;padding:16px;min-height:140px;border:1px solid #0ea5e9;\">\n      <div style=\"font-size:12px;opacity:.9;margin-bottom:6px;\">1,000 Points</div>\n      <div style=\"font-weight:800;font-size:18px;line-height:1.2;\">Refer a Partner, Get 